# Frontend environment variables.
#
# Copy to `.env.local` for local overrides; `.env.local` is gitignored.
# Vercel injects production values at build time via project settings.

# Base URL of the cpu-analytics backend.
# - Dev (default if unset): http://127.0.0.1:8000
# - Production: https://cpu-analytics-backend.onrender.com
VITE_API_BASE=http://127.0.0.1:8000
