__pycache__/
*.pyc
.venv/
venv/
.env
# All preprocess outputs land in data/processed/. Currently includes
# openipf.parquet, qt_standards.parquet, athlete_projection_tables.json
# (added 2026-04-23 with AP table serialization). All regenerated by
# `data/preprocess.py` and the weekly refresh-data.yml workflow; nothing
# in this dir is ever committed — backend downloads from GitHub Releases
# at cold start.
data/processed/
# qt_current.csv is produced by the weekly qt_refresh workflow and
# published to the data-latest release. The backend downloads it at
# cold start; the file is never committed.
data/qt_current.csv
# Diff summary is a transient scraper artefact; only the CSV + snapshot
# are canonical. --dry-run writes this next to qt_current.csv.
data/qt_diff_summary.md
# Local scraper output dir (used by manual --dry-run invocations).
scraper_out/
frontend/node_modules/
frontend/dist/
.DS_Store

# Claude Code per-project hook/config/launch directory.
.claude/

# Verification scratch files from VSCode Claude verification runs.
# These are ad-hoc curl dumps, not source of truth.
/prog_*.json
/qt_blocks.json
/qt_coverage_*.json
/manual_test.json
